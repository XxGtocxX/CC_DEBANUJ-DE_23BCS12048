#include<bits/stdc++.h>
using namespace std;
int singleNumber(vector<int>& nums) {
    int result = 0;

    for(int i = 0; i < 32; i++) {
        int sum = 0;

        for(int num : nums) {
            if((num >> i) & 1) {
                sum++;
            }
        }

        if(sum % 3) {
            result |= (1 << i);
        }
    }

    return result;
}
int main() {
    vector<int> nums = {1, 3, 1, 1, 2, 2, 2};
    int result = singleNumber(nums);
    cout << "Number: " << result << endl;
    
    return 0;
}
#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int bagOfTokensScore(vector<int>& tokens, int power) {
    sort(tokens.begin(), tokens.end());

    int l = 0;
    int r = tokens.size() - 1;
    int score = 0;
    int maxScore = 0;

    while(l <= r) {

        if(power >= tokens[l]) {
            power -= tokens[l];
            score++;
            l++;
            maxScore = max(maxScore, score);
        }

        else if(score > 0) {
            power += tokens[r];
            score--;
            r--;
        }

        else {
            break;
        }
    }

    return maxScore;
}

int main() {
    vector<int> tokens = {200, 150};
    int power = 150;
    int result = bagOfTokensScore(tokens, power);

    cout << "Maximum Score: " << result << endl;

    return 0;
}

